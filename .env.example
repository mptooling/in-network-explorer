# ── Required ──────────────────────────────────────────────────────────────────
AWS_REGION=eu-central-1
DYNAMO_TABLE=prospects-dev
LINKEDIN_COOKIES_SECRET=li-cookies-local
CHROME_PROFILE_DIR=/tmp/chrome-profile-dev

# ── Local development (comment out for real AWS) ─────────────────────────────
DYNAMO_ENDPOINT=http://localhost:8881
SECRETS_ENDPOINT=http://localhost:4566

# ── AWS / Bedrock (optional, defaults shown) ─────────────────────────────────
# BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_REGION=eu-central-1

# ── Proxy (optional) ─────────────────────────────────────────────────────────
# PROXY_ADDR=proxy.example.com:8080
# PROXY_USER=user
# PROXY_PASS=pass

# ── Chrome (optional, auto-detected if empty) ────────────────────────────────
# CHROME_BIN=/usr/bin/chromium

# ── Qdrant (optional, defaults shown) ────────────────────────────────────────
# QDRANT_ADDR=localhost:6333
# QDRANT_COLLECTION=prospects

# ── Search (required for scrape command) ─────────────────────────────────────
SEARCH_QUERY=software engineer
SEARCH_LOCATION=Berlin

# ── Operational (optional, defaults shown) ───────────────────────────────────
# MAX_PROFILE_VIEWS_PER_DAY=40
# MAX_CONNECTION_REQS_PER_DAY=10
# MAX_PROSPECTS_PER_RUN=20
# ANALYZE_CONCURRENCY=3
# BROWSER_MAX_NAVS=50
# REPORT_OUTPUT_DIR=reports
# PROMPT_CONFIG_PATH=prompts/scoring.json
