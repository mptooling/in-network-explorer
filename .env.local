# Local development defaults — copy to .env and adjust as needed.
# These values point to Docker Compose services started via `make dev`.

# Required
AWS_REGION=eu-central-1
DYNAMO_TABLE=prospects-dev
LINKEDIN_COOKIES_SECRET=li-cookies-local
CHROME_PROFILE_DIR=/tmp/chrome-profile-dev

# Local service endpoints (connects to Docker Compose services)
DYNAMO_ENDPOINT=http://localhost:8881
SECRETS_ENDPOINT=http://localhost:4566

# Qdrant (defaults match Docker Compose)
QDRANT_ADDR=localhost:6334
QDRANT_COLLECTION=prospects

# Bedrock (no local equivalent — requires real AWS creds or skip)
# BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_REGION=us-east-1
